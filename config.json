{
  "xml_feeds": {
    "gastromarket": {
      "url": "https://www.gastromarket.sk/product_data/partner_feed_sk.xml",
      "root_element": "channel",
      "item_element": "item",
      "namespace": "http://base.google.com/ns/1.0",
      "mapping": {
        "KATALOG_CISLO": "code",
        "MENO": "name",
        "POPIS": "shortDescription",
        "CENA_KATALOG": "price",
        "KATEGORIA_KOMPLET": "defaultCategory",
        "OBRAZOK_1": "IMAGE"
      }
    },
    "gastromarket_stalgast": {
      "url": "https://www.gastromarket.sk/product_data/B2B_Product_Feed_Stalgast.xml",
      "root_element": "channel",
      "item_element": "item",
      "namespace": "http://base.google.com/ns/1.0",
      "mapping": {
        "KATALOG_CISLO": "code",
        "MENO": "name",
        "POPIS": "shortDescription",
        "CENA_KATALOG": "price",
        "KATEGORIA_KOMPLET": "defaultCategory",
        "OBRAZOK_1": "IMAGE"
      }
    },
    "forgastro": {
      "url": "https://www.forgastro.sk/xml",
      "root_element": "products",
      "item_element": "product",
      "mapping": {
        "product_sku": "code",
        "product_name": "name",
        "product_price": "price",
        "manufacturer": "manufacturer",
        "category": "defaultCategory",
        "product_s_desc": "shortDescription",
        "product_desc": "description",
        "images/item/url": "IMAGES",
        "product_weight": "weight"
      }
    }
  },
  "output_mapping": {
    "comment": "Maps internal columns to new output format",
    "mappings": {
      "Kat. číslo": "code",
      "Kat. číslo rodiča": "pairCode",
      "Názov tovaru": "name",
      "Variant": "variant:Objem boxu",
      "Dĺžka": "variant:Dĺžka (mm)",
      "Hĺbka": "variant:Hĺbka (mm)",
      "Šírka": "variant:Šírka (mm)",
      "Bežná cena": "price",
      "Krátky popis": "shortDescription",
      "Dlhý popis": "description",
      "Výrobca": "manufacturer",
      "SEO titulka": "seoTitle",
      "SEO popis": "metaDescription",
      "Váha": "weight",
      "Súvisiace tovary": "relatedProduct",
      "Spracovane AI": "aiProcessed",
      "AI_Processed_Date": "aiProcessedDate"
    },
    "special_mappings": {
      "comment": "Special transformation rules for specific columns",
      "Hlavna kategória": {
        "target_columns": [
          "defaultCategory",
          "categoryText"
        ],
        "transform": "add_prefix_and_replace_separator",
        "prefix": "Gastro Prevádzky a Profesionáli > ",
        "replace": {
          "/": " > "
        }
      },
      "Kat. číslo": {
        "target_columns": [
          "code"
        ],
        "transform": "uppercase"
      },
      "Obrázky": {
        "target_columns": [
          "image",
          "image2",
          "image3",
          "image4",
          "image5",
          "image6",
          "image7"
        ],
        "transform": "split_by_comma",
        "comment": "Split comma-separated image URLs into multiple columns"
      }
    },
    "drop_columns": [
      "SEO kľúčové slová"
    ],
    "default_values": {
      "comment": "Default values applied only if column is empty or missing",
      "currency": "EUR",
      "includingVat": "0",
      "percentVat": "23",
      "unit": "ks",
      "itemType": "product",
      "priceRatio": "1",
      "freeShipping": "0",
      "freeBilling": "0",
      "applyDiscountCoupon": "1",
      "applyLoyaltyDiscount": "1",
      "applyQuantityDiscount": "1",
      "applyVolumeDiscount": "1",
      "stock": "0",
      "negativeAmount": "1",
      "decimalCount": "0",
      "firmyCz": "1",
      "productVisibility": "visible",
      "adult": "0",
      "atypicalShipping": "0",
      "atypicalBilling": "0",
      "actionFlagActive": "0",
      "tipFlagActive": "0",
      "newFlagActive": "0",
      "custom1FlagActive": "0",
      "custom2FlagActive": "0",
      "custom3FlagActive": "0",
      "allowsIPlatba": "1",
      "allowsPayOnline": "1",
      "heurekaHidden": "0",
      "heurekaCartHidden": "0",
      "zboziHidden": "0",
      "arukeresoHidden": "0",
      "arukeresoMarketplaceHidden": "0"
    }
  },
  "ai_enhancement": {
    "enabled": true,
    "model": "gemini-2.5-flash-lite",
    "batch_size": 30,
    "temperature": 0.1,
    "retry_attempts": 3,
    "retry_delay": 60,
    "max_parallel_calls": 10
  },
